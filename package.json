{
  "name": "chuumai-tools",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build --continue=dependencies-successful",
    "dev": "turbo run dev",
    "check": "turbo run check --continue",
    "lint": "turbo run lint --continue && eslint *.js",
    "format": "turbo run format --continue && eslint *.js --fix",
    "test": "turbo run test --continue"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/node": "^24.12.2",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "^24.11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@remotion/eslint-config-flat>typescript-eslint": "^8.57.1"
    }
  }
}
