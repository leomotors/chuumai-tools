{
  "name": "@repo/ui",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src",
    "format": "eslint src --fix"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./atom/*": {
      "types": "./src/atom/*/index.ts",
      "svelte": "./src/atom/*/index.ts",
      "default": "./src/atom/*/index.ts"
    },
    "./molecule/*": {
      "types": "./src/molecule/*/index.ts",
      "svelte": "./src/molecule/*/index.ts",
      "default": "./src/molecule/*/index.ts"
    },
    "./templates/*": {
      "types": "./src/templates/*",
      "svelte": "./src/templates/*",
      "default": "./src/templates/*"
    },
    "./icons/*": {
      "types": "./src/icons/*",
      "svelte": "./src/icons/*",
      "default": "./src/icons/*"
    },
    "./globals.css": "./src/globals.css",
    "./utils": {
      "types": "./src/utils.ts",
      "default": "./src/utils.ts",
      "svelte": "./src/utils.ts"
    }
  },
  "dependencies": {
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.7.0",
    "bits-ui": "^2.16.4",
    "clsx": "^2.1.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "svelte": "^5.55.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "layerchart": "2.0.0-next.43",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte-check": "^4.4.5",
    "typescript": "^6.0.2"
  }
}
